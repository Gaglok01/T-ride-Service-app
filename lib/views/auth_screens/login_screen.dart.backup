import 'package:flutter/material.dart';
import 'package:flutter_screenutil/flutter_screenutil.dart';
import 'package:get/get.dart';
import 'package:t_ride_rider_app/data/local/secure_storage_service.dart';
import 'package:t_ride_rider_app/data/repositories/auth_repository.dart';
import 'package:t_ride_rider_app/localization/app_translations.dart';
import 'package:t_ride_rider_app/views/auth_screens/language_selection_screen.dart';
import 'package:t_ride_rider_app/views/custom_navbar/navbar.dart';
import 'package:t_ride_rider_app/widgets/app_snackbar.dart';

import '../../consts/appConst.dart';

class LoginScreen extends StatefulWidget {
  const LoginScreen({super.key});

  @override
  State<LoginScreen> createState() => _LoginScreenState();
}

class _LoginScreenState extends State<LoginScreen> {
  final TextEditingController _identifierController = TextEditingController();
  final TextEditingController _passwordController = TextEditingController();
  final AuthRepository _authRepository = AuthRepository();
  final SecureStorageService _storageService = SecureStorageService();

  bool _isPasswordObscured = true;
  bool _isLoading = false;
  String _currentLanguageCode = Get.locale?.languageCode ?? 'en';

  final List<Map<String, String>> _languages = const [
    {'code': 'en', 'labelKey': 'lang.english'},
    {'code': 'fr', 'labelKey': 'lang.french'},
    {'code': 'es', 'labelKey': 'lang.spanish'},
    {'code': 'ar', 'labelKey': 'lang.arabic'},
    {'code': 'zh', 'labelKey': 'lang.mandarin'},
  ];

  @override
  void dispose() {
    _identifierController.dispose();
    _passwordController.dispose();
    super.dispose();
  }

  bool get _isFormValid =>
      _identifierController.text.trim().isNotEmpty &&
      _passwordController.text.trim().length >= 6;

  bool _userHasDriverId(dynamic user) {
    if (user is! Map) return false;
    final m = Map<String, dynamic>.from(user);
    final v = m['driver_id'];
    if (v == null) return false;
    if (v is String) {
      final t = v.trim();
      if (t.isEmpty || t.toLowerCase() == 'null') return false;
      final n = int.tryParse(t);
      if (n != null) return n != 0;
      return true;
    }
    if (v is num) return v != 0;
    return true;
  }

  Future<void> _onLoginPressed() async {
    if (!_isFormValid || _isLoading) return;
    FocusScope.of(context).unfocus();
    setState(() => _isLoading = true);

    try {
      final response = await _authRepository.login(
        identifier: _identifierController.text.trim(),
        password: _passwordController.text,
      );

      final status = response['status'];
      if (status == true || status == 1) {
        if (_userHasDriverId(response['user'])) {
          if (mounted) {
            AppSnackBar.show('T-Ride', 'This is the rider app. Please use the driver app for driver accounts.');
          }
          return;
        }

        final token = response['token'] as String?;
        if (token != null && token.isNotEmpty) {
          await _storageService.saveAuthToken(token);
        }

        if (!mounted) return;
        Get.offAll(() => const Navbar());
      } else {
        final message = (response['message'] ?? 'Unable to sign in. Please check your account and try again.').toString();
        if (mounted) AppSnackBar.show('Sign in failed', message);
      }
    } catch (e) {
      if (mounted) {
        AppSnackBar.show('Something went wrong', 'Please try again.');
      }
    } finally {
      if (mounted) setState(() => _isLoading = false);
    }
  }

  Future<void> _onLanguageChanged(String? code) async {
    if (code == null || code == _currentLanguageCode) return;
    final locale = AppTranslations.localeForLanguageCode(code);
    setState(() => _currentLanguageCode = code);
    await _storageService.saveAppLocaleLanguageCode(code);
    Get.updateLocale(locale);
  }

  void _onSignUpPressed() => Get.to(() => const LanguageSelectionScreen());

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFF7F8FA),
      body: SafeArea(
        child: SingleChildScrollView(
          padding: EdgeInsets.fromLTRB(22.w, 22.h, 22.w, 28.h),
          child: ConstrainedBox(
            constraints: BoxConstraints(
              minHeight: MediaQuery.of(context).size.height - MediaQuery.of(context).padding.vertical - 50.h,
            ),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                _buildTopBar(),
                SizedBox(height: 34.h),
                _buildBrandHeader(),
                SizedBox(height: 28.h),
                _buildLoginCard(),
                SizedBox(height: 18.h),
                _buildSafetyNote(),
                SizedBox(height: 22.h),
                Center(
                  child: TextButton(
                    onPressed: _onSignUpPressed,
                    child: Text(
                      'Create a T-Ride account',
                      style: TextStyle(
                        color: AppConst.black,
                        fontSize: 14.sp,
                        fontWeight: FontWeight.w800,
                        decoration: TextDecoration.underline,
                      ),
                    ),
                  ),
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildTopBar() {
    return Row(
      children: [
        Container(
          width: 42.w,
          height: 42.w,
          decoration: BoxDecoration(
            color: AppConst.black,
            borderRadius: BorderRadius.circular(14.r),
          ),
          child: Icon(Icons.local_taxi_rounded, color: AppConst.primaryColor, size: 23.sp),
        ),
        SizedBox(width: 10.w),
        Text(
          'T-Ride',
          style: TextStyle(color: AppConst.black, fontSize: 20.sp, fontWeight: FontWeight.w900),
        ),
        const Spacer(),
        DropdownButtonHideUnderline(
          child: Container(
            padding: EdgeInsets.symmetric(horizontal: 10.w, vertical: 3.h),
            decoration: BoxDecoration(
              color: Colors.white,
              borderRadius: BorderRadius.circular(18.r),
              border: Border.all(color: const Color(0xFFE6E8EC)),
            ),
            child: DropdownButton<String>(
              value: _currentLanguageCode,
              isDense: true,
              icon: Icon(Icons.keyboard_arrow_down_rounded, size: 18.sp),
              borderRadius: BorderRadius.circular(16.r),
              items: _languages.map((lang) {
                return DropdownMenuItem<String>(
                  value: lang['code'],
                  child: Text(lang['labelKey']!.tr, style: TextStyle(fontSize: 12.sp, fontWeight: FontWeight.w700)),
                );
              }).toList(),
              onChanged: _onLanguageChanged,
            ),
          ),
        ),
      ],
    );
  }

  Widget _buildBrandHeader() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
          'Move around with confidence.',
          style: TextStyle(
            color: AppConst.black,
            fontSize: 31.sp,
            height: 1.05,
            letterSpacing: -1.2,
            fontWeight: FontWeight.w900,
          ),
        ),
        SizedBox(height: 12.h),
        Text(
          'Book rides, courier deliveries, and everyday services with a cleaner T-Ride experience.',
          style: TextStyle(color: AppConst.textSecondary, fontSize: 14.sp, height: 1.45, fontWeight: FontWeight.w500),
        ),
      ],
    );
  }

  Widget _buildLoginCard() {
    return Container(
      width: double.infinity,
      padding: EdgeInsets.all(18.w),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(28.r),
        border: Border.all(color: const Color(0xFFEDEEF2)),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withValues(alpha: 0.07),
            blurRadius: 24,
            offset: const Offset(0, 12),
          ),
        ],
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Text('Sign in', style: TextStyle(color: AppConst.black, fontSize: 22.sp, fontWeight: FontWeight.w900)),
          SizedBox(height: 5.h),
          Text('Access your rider account', style: TextStyle(color: AppConst.textSecondary, fontSize: 13.sp)),
          SizedBox(height: 20.h),
          _buildInput(
            controller: _identifierController,
            hint: 'Email or phone number',
            icon: Icons.person_outline_rounded,
            keyboardType: TextInputType.emailAddress,
          ),
          SizedBox(height: 12.h),
          _buildInput(
            controller: _passwordController,
            hint: 'Password',
            icon: Icons.lock_outline_rounded,
            obscureText: _isPasswordObscured,
            suffix: IconButton(
              icon: Icon(_isPasswordObscured ? Icons.visibility_off_outlined : Icons.visibility_outlined, color: AppConst.textSecondary),
              onPressed: () => setState(() => _isPasswordObscured = !_isPasswordObscured),
            ),
          ),
          SizedBox(height: 10.h),
          Align(
            alignment: Alignment.centerRight,
            child: TextButton(
              onPressed: () => AppSnackBar.show('Coming soon', 'Password reset will be connected to the backend.'),
              child: Text('Forgot password?', style: TextStyle(color: AppConst.black, fontSize: 12.sp, fontWeight: FontWeight.w700)),
            ),
          ),
          SizedBox(height: 8.h),
          SizedBox(
            width: double.infinity,
            height: 54.h,
            child: ElevatedButton(
              onPressed: _isFormValid && !_isLoading ? _onLoginPressed : null,
              style: ElevatedButton.styleFrom(
                backgroundColor: AppConst.black,
                foregroundColor: AppConst.white,
                disabledBackgroundColor: const Color(0xFFD9DDE4),
                elevation: 0,
                shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(18.r)),
              ),
              child: _isLoading
                  ? SizedBox(width: 20.w, height: 20.w, child: CircularProgressIndicator(strokeWidth: 2, color: AppConst.white))
                  : Text('Sign in', style: TextStyle(fontSize: 15.sp, fontWeight: FontWeight.w900)),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildInput({
    required TextEditingController controller,
    required String hint,
    required IconData icon,
    TextInputType? keyboardType,
    bool obscureText = false,
    Widget? suffix,
  }) {
    return Container(
      decoration: BoxDecoration(
        color: const Color(0xFFF6F7F9),
        borderRadius: BorderRadius.circular(18.r),
        border: Border.all(color: const Color(0xFFE6E8EC)),
      ),
      child: TextField(
        controller: controller,
        obscureText: obscureText,
        keyboardType: keyboardType,
        onChanged: (_) => setState(() {}),
        decoration: InputDecoration(
          border: InputBorder.none,
          prefixIcon: Icon(icon, color: AppConst.black, size: 21.sp),
          suffixIcon: suffix,
          hintText: hint,
          hintStyle: TextStyle(color: AppConst.textSecondary, fontSize: 14.sp, fontWeight: FontWeight.w500),
          contentPadding: EdgeInsets.symmetric(horizontal: 14.w, vertical: 16.h),
        ),
      ),
    );
  }

  Widget _buildSafetyNote() {
    return Container(
      padding: EdgeInsets.all(14.w),
      decoration: BoxDecoration(
        color: AppConst.primaryColor.withValues(alpha: 0.16),
        borderRadius: BorderRadius.circular(20.r),
      ),
      child: Row(
        children: [
          Icon(Icons.verified_user_outlined, color: AppConst.black, size: 21.sp),
          SizedBox(width: 10.w),
          Expanded(
            child: Text(
              'Your account stays protected. Driver login is separated for safety.',
              style: TextStyle(color: AppConst.black, fontSize: 12.sp, height: 1.35, fontWeight: FontWeight.w600),
            ),
          ),
        ],
      ),
    );
  }
}
